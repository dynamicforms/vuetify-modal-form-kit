{
  "name": "@dynamicforms/vuetify-modal-form-kit",
  "private": false,
  "version": "0.5.5",
  "type": "module",
  "description": "Vue 3 + Vuetify 3 library providing a promise-based programmatic dialog API with a sequential dialog queue, a TypeScript fluent form layout builder (FormBuilder), and built-in keyboard shortcuts for dialog (Enter/Esc).",
  "author": "Jure Erznožnik",
  "files": [
    "dist/*"
  ],
  "main": "dist/dynamicforms-vuetify-modal-form-kit.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/dynamicforms-vuetify-modal-form-kit.umd.cjs",
      "import": "./dist/dynamicforms-vuetify-modal-form-kit.js"
    }
  },
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "lint": "eslint src && vue-tsc --noEmit",
    "docs:dev": "npm run docs:dev -w docs",
    "docs:build": "npm run docs:build -w docs",
    "docs:preview": "npm run docs:preview -w docs"
  },
  "keywords": [
    "vue",
    "vue3",
    "vuetify",
    "dynamicforms",
    "velis",
    "form-layout",
    "form-builder",
    "modal",
    "dialog"
  ],
  "license": "MIT",
  "homepage": "https://docs.velis.si/dynamicforms/vuetify-modal-form-kit/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velis74/dynamicforms-vuetify-modal-form-kit.git"
  },
  "bugs": {
    "url": "https://github.com/velis74/dynamicforms-vuetify-modal-form-kit/issues"
  },
  "peerDependencies": {
    "@dynamicforms/vue-forms": "^0.5.0",
    "@dynamicforms/vuetify-inputs": "^0.7.13",
    "@mdi/font": "^7.4.47",
    "lodash-es": "^4.17.12",
    "vue": "^3.4",
    "vue-markdown-render": "^2.2.1",
    "vuetify": "^3.8"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^5",
    "@vitest/coverage-istanbul": "^3",
    "@vue/test-utils": "^2.2.4",
    "@vue/tsconfig": "^0.7.0",
    "eslint-config-velis": "^2.0.12",
    "jsdom": "^26.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5",
    "vite": "^5",
    "vite-plugin-dts": "^4",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^3",
    "vue-tsc": "^2"
  }
}
